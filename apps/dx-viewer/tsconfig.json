{
	"extends": "../../packages/tsconfig/svelte.json",
	"compilerOptions": {
		"allowJs": true,
		"paths": {
			"$lib": ["./src/lib"],
			"$lib/*": ["./src/lib/*"],
			"$components": ["./src/components"],
			"$components/*": ["./src/components/*"]
		}
	},
	"include": [
		".svelte-kit/ambient.d.ts",
		".svelte-kit/non-ambient.d.ts",
		".svelte-kit/types/**/$types.d.ts",
		"src/**/*.ts",
		"src/**/*.js",
		"src/**/*.svelte",
		"src/**/*.svelte.ts"
	],
	"exclude": ["node_modules", "build"]
}
