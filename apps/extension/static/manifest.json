{
	"manifest_version": 3,
	"name": "Be Certain",
	"version": "0.0.1",
	"description": "AI-powered dental X-ray analysis assistant",
	"permissions": ["activeTab", "tabs", "storage", "contextMenus", "scripting"],
	"host_permissions": ["<all_urls>"],
	"action": {},
	"background": {
		"service_worker": "background/index.js",
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content/index.js"],
			"run_at": "document_idle"
		}
	]
}
