{
	"name": "@be-certain/pb-openapi",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./types": {
			"types": "./src/types.ts",
			"default": "./src/types.ts"
		},
		"./constants": {
			"types": "./src/constants.ts",
			"default": "./src/constants.ts"
		},
		"./spec.yaml": "./spec.yaml"
	},
	"scripts": {
		"generate": "openapi-typescript ./spec.yaml -o ./src/types.ts",
		"check": "tsc --noEmit"
	},
	"devDependencies": {
		"openapi-typescript": "^7.4.0",
		"typescript": "^5.7.0"
	}
}
