{
	"name": "@be-certain/core",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"description": "PocketBase client + AI API + auth/prefs stores + shared types & constants (extracted from the dx-viewer app; consumed source-form via the svelte export condition).",
	"svelte": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"svelte": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./pb": {
			"types": "./src/pb.ts",
			"svelte": "./src/pb.ts",
			"default": "./src/pb.ts"
		},
		"./ai": {
			"types": "./src/ai.ts",
			"svelte": "./src/ai.ts",
			"default": "./src/ai.ts"
		},
		"./types": {
			"types": "./src/types.ts",
			"default": "./src/types.ts"
		},
		"./constants": {
			"types": "./src/constants.ts",
			"svelte": "./src/constants.ts",
			"default": "./src/constants.ts"
		},
		"./image": {
			"types": "./src/image.ts",
			"default": "./src/image.ts"
		},
		"./url": {
			"types": "./src/url.ts",
			"default": "./src/url.ts"
		},
		"./prefs": {
			"types": "./src/prefs.ts",
			"default": "./src/prefs.ts"
		},
		"./logger": {
			"types": "./src/logger.ts",
			"default": "./src/logger.ts"
		},
		"./errors": {
			"types": "./src/errors.ts",
			"default": "./src/errors.ts"
		},
		"./stores/auth": {
			"types": "./src/stores/auth.svelte.ts",
			"svelte": "./src/stores/auth.svelte.ts",
			"default": "./src/stores/auth.svelte.ts"
		},
		"./stores/prefs": {
			"types": "./src/stores/prefs.svelte.ts",
			"svelte": "./src/stores/prefs.svelte.ts",
			"default": "./src/stores/prefs.svelte.ts"
		}
	},
	"dependencies": {
		"pocketbase": "^0.26.9",
		"svelte-i18n": "^4.0.1"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"svelte": "^5.55.2",
		"typescript": "^6.0.2"
	}
}
