{
	"name": "@be-certain/imaging-3d",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"description": "three.js-stack 3D imaging compute: CBCT volume parsing (NIfTI/NRRD), remeshing, measurements, FDI labelling, seg gating (extracted from the dx-viewer app; UI components stay app-side).",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./volumeLoader": "./src/volumeLoader.ts",
		"./remeshCache": "./src/remeshCache.ts",
		"./renderableModel": "./src/renderableModel.ts",
		"./gltfStats": "./src/gltfStats.ts",
		"./findingLabel": "./src/findingLabel.ts",
		"./meshLabel": "./src/meshLabel.ts",
		"./measure": "./src/measure.ts",
		"./iosFdi": "./src/iosFdi.ts",
		"./anatomyCounts": "./src/anatomyCounts.ts",
		"./denoiseGuard": "./src/denoiseGuard.ts",
		"./disposeObject3D": "./src/disposeObject3D.ts",
		"./segGate": "./src/segGate.ts",
		"./state": {
			"types": "./src/state.svelte.ts",
			"svelte": "./src/state.svelte.ts",
			"default": "./src/state.svelte.ts"
		}
	},
	"dependencies": {
		"@be-certain/core": "workspace:*",
		"nifti-reader-js": "^0.8.0",
		"nrrd-js": "^0.2.1",
		"pako": "^2.1.0",
		"three": "^0.184.0"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@types/three": "^0.184.1",
		"svelte": "^5.55.2",
		"typescript": "^6.0.2"
	}
}
